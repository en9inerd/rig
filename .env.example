# Global
RIG_PORT=8080
RIG_CORS_ORIGIN=
RIG_TELEGRAM_BOT_TOKEN=
RIG_STORE_PATH=/data/rig.json

RIG_VERBOSE=false

# TLS (optional — leave empty for plain HTTP)
RIG_TLS_CERT=
RIG_TLS_KEY=

# Visitor notifier
RIG_VISITOR_ENABLED=true
RIG_VISITOR_SITES_FILE=/data/visitors.json
RIG_VISITOR_GEOIP_DB=/data/geoip/GeoLite2-City.mmdb

# MaxMind GeoIP update (used by geoipupdate sidecar)
GEOIPUPDATE_ACCOUNT_ID=
GEOIPUPDATE_LICENSE_KEY=

# Feed watcher
RIG_FEED_ENABLED=true
RIG_FEED_URL=
RIG_FEED_INTERVAL=15m
RIG_FEED_CHAT_ID=

# IP watcher
RIG_IP_ENABLED=true
RIG_IP_INTERVAL=15m
RIG_IP_CHAT_ID=
